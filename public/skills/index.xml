      <description>&lt;style&gt;
.skill-detail {
  max-width: 1100px;
  margin: 0 auto;
}

.skill-header {
  text-align: center;
  padding: 3rem 0;
  background: linear-gradient(135deg, rgba(239, 68, 68, 0.1), rgba(249, 115, 22, 0.1));
  border-radius: 16px;
  margin-bottom: 2rem;
}

.skill-icon-large {
  font-size: 4rem;
  margin-bottom: 1rem;
}

.skill-title {
  font-size: 2.5rem;
  font-weight: 700;
  margin: 0 0 1rem 0;
  color: var(--primary);
}

.skill-desc {
  font-size: 1.1rem;
  color: var(--text-muted);
  margin-bottom: 1.5rem;
}

.skill-tags {
  display: flex;
  gap: 0.5rem;
  justify-content: center;
  flex-wrap: wrap;
}

.skill-tag {
  padding: 0.3rem 0.8rem;
  border-radius: 20px;
  font-size: 0.85rem;
  font-weight: 500;
}

.skill-tag.official { background: #ef4444; color: white; }
.skill-tag.local { background: #3b82f6; color: white; }
.skill-tag.cloud { background: #8b5cf6; color: white; }

.section {
  margin: 3rem 0;
}

.section h2 {
  font-size: 1.6rem;
  color: var(--primary);
  border-bottom: 2px solid var(--primary);
  padding-bottom: 0.5rem;
  margin-bottom: 1.5rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.tool-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1rem;
  margin: 1.5rem 0;
}

.tool-card {
  background: var(--code-bg);
  border-radius: 12px;
  padding: 1.25rem;
  border: 1px solid var(--border);
  transition: transform 0.2s, box-shadow 0.2s;
}

.tool-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(0,0,0,0.15);
}

.tool-card h4 {
  margin: 0 0 0.5rem 0;
  font-size: 1.1rem;
}

.tool-card h4 a {
  color: var(--primary);
  text-decoration: none;
}

.tool-card h4 a:hover {
  text-decoration: underline;
}

.tool-card .tool-meta {
  font-size: 0.8rem;
  color: var(--text-muted);
  margin-bottom: 0.75rem;
}

.tool-card p {
  margin: 0;
  font-size: 0.9rem;
  color: var(--text);
  line-height: 1.5;
}

.tool-card .tool-quote {
  margin-top: 0.75rem;
  padding-left: 0.75rem;
  border-left: 3px solid var(--primary);
  font-size: 0.85rem;
  color: var(--text-muted);
  font-style: italic;
}
&lt;/style&gt;
&lt;div class=&#34;skill-detail&#34;&gt;
&lt;div class=&#34;skill-header&#34;&gt;
  &lt;div class=&#34;skill-icon-large&#34;&gt;🦞&lt;/div&gt;
  &lt;h1 class=&#34;skill-title&#34;&gt;2026年「龙虾」最新集合&lt;/h1&gt;
  &lt;p class=&#34;skill-desc&#34;&gt;最适合中国人体质的龙虾集合 · 共收录 19 个工具&lt;/p&gt;</description>
