<script src="https://beacon.cdn.qq.com/sdk/4.7.5/beacon_web.min.js"></script>
<script src="https://beacon.cdn.qq.com/auto_tracker/js/autotracker-beacon-oa-4.4.3.min.js"></script>
<script src="./report.obf.js"></script>
<script src="./download.obf.js"></script>

<script>
  // 埋点初始化：所有上报逻辑由 report.js 统一管理
  window.addEventListener('DOMContentLoaded', () => {
    if (window.QclawReport) {
      window.QclawReport.init();
    }
  });
</script>

<script>
let mouseX=-100,mouseY=-100;
window.addEventListener('scroll',()=>{document.getElementById('navbar').classList.toggle('scrolled',window.scrollY>50);});

const obs=new IntersectionObserver(entries=>{entries.forEach((e,i)=>{if(e.isIntersecting)setTimeout(()=>e.target.classList.add('visible'),i*60);});},{threshold:0.1});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

document.querySelectorAll('.demo-card').forEach(card=>{card.addEventListener('mousemove',e=>{const r=card.getBoundingClientRect();const rx=(e.clientY-r.top-r.height/2)/(r.height/2)*-3;const ry=(e.clientX-r.left-r.width/2)/(r.width/2)*3;card.style.transform=`translateY(-8px) perspective(800px) rotateX(${rx}deg) rotateY(${ry}deg)`;});card.addEventListener('mouseleave',()=>{card.style.transform='translateY(0) perspective(800px) rotateX(0) rotateY(0)';});});
</script>
</body>
</html>

